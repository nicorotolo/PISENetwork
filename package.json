{
  "name": "minimal-mistakes",
  "private": true,
  "version": "4.26.2",
  "description": "Minimal Mistakes 2 column Jekyll theme.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mmistakes/minimal-mistakes.git"
  },
  "keywords": [
    "jekyll",
    "theme",
    "minimal"
  ],
  "author": "Michael Rose",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/mmistakes/minimal-mistakes/issues"
  },
  "homepage": "https://mmistakes.github.io/minimal-mistakes/",
  "scripts": {
    "build:main-css": "sass assets/css/main.scss assets/css/main.css --style=compressed",
    "build:custom-css": "sass assets/css/custom.scss assets/css/custom.css --style=compressed",
    "build:css": "npm run build:main-css && npm run build:custom-css",
    "watch:css": "sass --watch assets/css/main.scss:assets/css/main.css assets/css/custom.scss:assets/css/custom.css --style=compressed"
  },
  "engines": {
    "node": ">= 0.10.0"
  },
  "devDependencies": {
    "uglify-js": "^3.17.4"
  },
  "dependencies": {
    "bootstrap": "^5.3.3"
  }
}
